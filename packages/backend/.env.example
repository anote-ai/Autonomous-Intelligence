# Application
APP_ENV=local
IS_PROD=false
PORT=5000

# Database
DB_HOST=localhost
DB_NAME=anote
DB_USER=root
DB_PASSWORD=

# Cache
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET_KEY=change-me-in-production

# LLM Providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Stripe (optional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Storage
UPLOAD_FOLDER=/tmp/anote_uploads
CHROMA_PERSIST_DIR=./chroma_db
